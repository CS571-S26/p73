# --- API server (Node). Copy to ".env" in the project root and fill in values.
# Never commit ".env" — it is gitignored.

# Required: create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-5.4-mini

# Optional: API listen port (default 8787). Must match Vite proxy target in vite.config.ts.
# PORT=8787

# Server truncates text beyond ~8k chars before calling OpenAI; completion capped at 8 tokens.

# --- Frontend (Vite). Optional for local dev (Vite proxies /api to the server above).
# For production, set to the public origin of your deployed API (no trailing slash).
# VITE_API_BASE_URL=https://your-api.example.com
